// VS Code「Reopen in Container」或 GitHub Codespaces 開啟專案時，會讀取這個檔案來建立開發環境
{
  "name": "laravel-app-dev",

  // 透過 docker-compose.yml 啟動所有服務（app、MySQL、Redis）
  "dockerComposeFile": "../docker-compose.yml",

  // 開發者操作的主要容器（對應 docker-compose.yml 裡的 app 服務）
  "service": "app",

  // 容器啟動後，VS Code 會開啟這個資料夾作為工作目錄
  // 這個路徑要和 docker-compose.yml 裡 app 的 bind mount 目標路徑一致
  "workspaceFolder": "/workspaces/php-laravel-sample",

  "remoteUser": "root",

  // 關閉 VS Code 視窗時，一併停止所有 docker-compose 服務
  "shutdownAction": "stopCompose",

  // VS Code 在容器內自動安裝的擴充套件與設定
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client", // PHP 智慧提示（Intelephense）
        "shufo.vscode-blade-formatter",        // Blade 模板格式化
        "onecentlin.laravel-blade",            // Blade 語法高亮
        "mikestead.dotenv",                    // .env 檔案語法高亮
        "redhat.vscode-yaml",                  // YAML 語法提示
        "EditorConfig.EditorConfig"            // EditorConfig 支援
      ],
      "settings": {
        "php.validate.executablePath": "/usr/local/bin/php",
        "intelephense.environment.phpVersion": "8.3.0",
        "terminal.integrated.defaultProfile.linux": "bash",
        "[php]": {
          "editor.defaultFormatter": "bmewburn.vscode-intelephense-client"
        },
        "[blade]": {
          "editor.defaultFormatter": "shufo.vscode-blade-formatter"
        }
      }
    }
  },

  // 讓本機可以直接用 localhost 連到容器內的這些 port
  "forwardPorts": [8000, 3306, 6379],

  "postCreateCommand": "echo 'Dev container ready.'",

  "mounts": [
    // 把 Composer 下載的套件快取存到獨立的 Docker volume
    // 這樣重建容器時不用重新下載所有依賴，節省時間
    "source=composer_cache,target=/root/.composer,type=volume"
  ]
}
